NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Supabase is the default backend: Auth, Postgres, Storage.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ADMIN_EMAILS=

# Resend powers contact/support notifications.
RESEND_API_KEY=
RESEND_FROM="ASCII Template <hello@example.com>"
CONTACT_TO_EMAIL=hello@example.com

# Optional SEO ping route.
INDEXNOW_KEY=

# Set to true only when you deliberately want to disable first-party analytics.
DISABLE_FIRST_PARTY_ANALYTICS=false
